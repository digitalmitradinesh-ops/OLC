# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GMAIL_USER: Your Gmail email address to send OTP verification codes from (e.g. your-email@gmail.com).
# Configure this in the AI Studio UI settings under Environment Variables / Secrets.
GMAIL_USER=""

# GMAIL_APP_PASSWORD: A 16-character Google App Password (NOT your normal Gmail login password).
# To generate one: Go to Google Account Settings -> Security -> 2-Step Verification -> App Passwords.
# Enter a name like "LocalMarket OTP" and copy the 16-letter code.
GMAIL_APP_PASSWORD=""

